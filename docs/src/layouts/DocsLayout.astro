---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const all = await getCollection("docs");
const nav = [...all].sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const base = import.meta.env.BASE_URL;
const github =
  import.meta.env.PUBLIC_GITHUB_REPO_URL ?? "https://github.com/YOUR_ORG/vcli";
---

<Layout title={`${title} · g docs`} description={description}>
  <a href="#main" class="sr-only">Skip to content</a>
  <header
    style="border-bottom:1px solid var(--border); backdrop-filter: blur(12px); background: rgba(7,8,13,0.75); position: sticky; top: 0; z-index: 40;"
  >
    <div
      class="wrap"
      style="display:flex; align-items:center; justify-content: space-between; gap: 1rem; padding: 1rem 0; flex-wrap: wrap;"
    >
      <a
        href={`${base}`}
        style="font-weight: 700; letter-spacing: -0.02em; color: var(--text); text-decoration: none;"
      >
        g
      </a>
      <nav aria-label="Primary" style="display:flex; gap: 1.25rem; align-items:center; flex-wrap: wrap;">
        <a href={`${base}#features`} style="color: var(--muted);">Features</a>
        <a href={`${base}#install`} style="color: var(--muted);">Install</a>
        <a href={`${base}docs/introduction/`} style="color: var(--muted);">Documentation</a>
        <a href={github} style="color: var(--muted);" rel="noopener noreferrer">
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <div class="wrap docs-shell" id="main">
    <aside style="position: sticky; top: 5.5rem; align-self: start;">
      <p style="margin: 0 0 0.75rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">
        Documentation
      </p>
      <nav aria-label="Docs" style="display:flex; flex-direction: column; gap: 0.35rem;">
        {
          nav.map((entry) => {
            const href = `${base}docs/${entry.slug}/`;
            return (
              <a
                href={href}
                style="color: var(--muted); font-size: 0.95rem; padding: 0.25rem 0;"
              >
                {entry.data.title}
              </a>
            );
          })
        }
      </nav>
    </aside>
    <article
      class="prose"
      style="min-width: 0; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 2rem 2.25rem; box-shadow: var(--shadow);"
    >
      <h1 style="margin-top: 0; font-size: 2rem; letter-spacing: -0.03em;">{title}</h1>
      <slot />
    </article>
  </div>

  <style is:global>
    .prose h2 {
      margin-top: 2rem;
      font-size: 1.35rem;
      letter-spacing: -0.02em;
    }
    .prose h3 {
      margin-top: 1.5rem;
      font-size: 1.1rem;
    }
    .prose p,
    .prose li {
      color: #c4c6d4;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    .prose th,
    .prose td {
      border: 1px solid var(--border);
      padding: 0.5rem 0.65rem;
      text-align: left;
    }
    .prose th {
      background: var(--bg-elevated);
    }
    .docs-shell {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 2.5rem;
      padding: 2.5rem 0 4rem;
    }
    @media (max-width: 860px) {
      .docs-shell {
        grid-template-columns: 1fr;
      }
      aside {
        position: static !important;
      }
    }
  </style>
</Layout>
