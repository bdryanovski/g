---
import Layout from "@/layouts/Layout.astro";
import AppHeader from "@/components/AppHeader.astro";
import TerminalDemo from "@/components/react/TerminalDemo";

const base = import.meta.env.BASE_URL;
const github =
  import.meta.env.PUBLIC_GITHUB_REPO_URL ?? "https://github.com/YOUR_ORG/vcli";

const uc = `${base}docs/use-cases/`;
const plays = [
  {
    title: "Huge feature, tiny PRs",
    desc: "You are weeks into one branch—split schema, API, and webhooks into a stack and chained PRs.",
    tag: "Story",
    tagClass: "tag--violet",
    href: `${uc}#split-a-huge-feature-into-stacked-prs`,
  },
  {
    title: "Prod breaks mid-feature",
    desc: "Pager fires while your tree is dirty—open a hotfix worktree, ship, delete, never stash your life.",
    tag: "Story",
    tagClass: "tag--cyan",
    href: `${uc}#hotfix-production-without-abandoning-your-feature-branch`,
  },
  {
    title: "Review without GitHub",
    desc: "Lead a triage: compare commits and stats from the terminal before you open the big diff.",
    tag: "Story",
    tagClass: "tag--lime",
    href: `${uc}#review-a-branch-without-opening-github-for-history`,
  },
  {
    title: "Same diff for the team",
    desc: "Pin delta once in config so every screenshot and local review matches.",
    tag: "Story",
    tagClass: "tag--rose",
    href: `${uc}#make-diffs-look-the-same-for-everyone-on-the-team`,
  },
];
---

<Layout
  title="g — Git, upgraded"
  description="A Rust Git CLI with stacked PRs, workspaces, and enhanced log & diff. Passthrough-compatible with git."
>
  <AppHeader base={base} github={github} />

  <main class="home-main">
    <section class="wrap-wide home-hero">
      <div class="home-hero-grid">
        <div class="home-hero-copy">
          <span class="tag tag--cyan home-hero-eyebrow">Developer tool</span>
          <h1 class="home-hero-title">
            Git workflows,
            <span class="home-hero-grad">supercharged</span>
          </h1>
          <p class="home-hero-lede">
            <strong class="home-hero-strong">g</strong> passes through every <code>git</code> command, then upgrades the commands you run all day—log, diff, status, branch—and adds <strong>stacks</strong> and <strong>workspaces</strong> for serious branch hygiene.
          </p>
          <div class="home-hero-actions">
            <a class="btn btn-primary" href={`${base}docs/use-cases/`}>Explore use cases</a>
            <a class="btn btn-ghost" href={`${base}docs/installation/`}>Install</a>
          </div>
          <ul class="home-hero-bullets" aria-label="Highlights">
            <li>Passthrough-compatible with git</li>
            <li>Stacked PRs + GitHub API</li>
            <li>Worktree-native workspaces</li>
          </ul>
        </div>
        <div class="home-hero-panel">
          <TerminalDemo client:load />
        </div>
      </div>
    </section>

    <section id="use-cases" class="wrap-wide home-section">
      <div class="home-section-head">
        <h2 class="home-section-title">Use cases</h2>
        <p class="home-section-sub">
          Each card jumps to a <strong>story-style playbook</strong> (who you are, what to run, why). The full list lives in <a href={`${base}docs/use-cases/`}>Use cases</a>—including solo workflows, release prep, and stack repair.
        </p>
      </div>
      <div class="home-plays">
        {
          plays.map((p) => (
            <a href={p.href} class="home-play-card">
              <span class:list={["tag", p.tagClass]}>{p.tag}</span>
              <span class="home-play-title">{p.title}</span>
              <span class="home-play-desc">{p.desc}</span>
              <span class="home-play-cta">Open guide →</span>
            </a>
          ))
        }
      </div>
    </section>

    <section id="features" class="wrap-wide home-section">
      <div class="home-section-head">
        <h2 class="home-section-title">Capabilities</h2>
        <p class="home-section-sub">
          Four areas where <strong>g</strong> goes beyond pretty printing: structure, parallelism, history, and patches.
        </p>
      </div>
      <div class="home-cap-grid">
        <article class="home-cap">
          <h3 class="home-cap-title">Stacks</h3>
          <p class="home-cap-body">
            Ordered branch chains, <code>sync</code> rebases, <code>push</code> the ladder, <code>pr</code> with correct bases on GitHub.
          </p>
          <p class="home-cap-cmd">
            <code>g stack new</code>
            <code>g stack sync</code>
            <code>g stack pr</code>
          </p>
        </article>
        <article class="home-cap">
          <h3 class="home-cap-title">Workspaces</h3>
          <p class="home-cap-body">
            Named <strong>git worktree</strong> checkouts as sibling directories; switch via subshell; list and prune safely.
          </p>
          <p class="home-cap-cmd">
            <code>g workspace create</code>
            <code>g workspace list</code>
            <code>g workspace switch</code>
          </p>
        </article>
        <article class="home-cap">
          <h3 class="home-cap-title">Log</h3>
          <p class="home-cap-body">
            Graph, decorations, conventional-commit coloring—still forwards args to <code>git log</code>.
          </p>
          <p class="home-cap-cmd">
            <code>g log</code>
            <code>g log --all</code>
            <code>g log main..HEAD</code>
          </p>
        </article>
        <article class="home-cap">
          <h3 class="home-cap-title">Diff</h3>
          <p class="home-cap-body">
            Auto-route through <strong>delta</strong> / <strong>diff-so-fancy</strong> or your own tool from config.
          </p>
          <p class="home-cap-cmd">
            <code>g diff</code>
            <code>g show</code>
            <code>g compare --diff</code>
          </p>
        </article>
      </div>
    </section>

    <section class="wrap-wide home-section">
      <div class="home-band">
        <div>
          <h2 class="home-band-title">Docs as Markdown</h2>
          <p class="home-band-text">
            Edit <code>docs/src/content/docs/</code>, tune frontmatter order, preview with <code>npm run dev</code>. GitHub Actions builds and ships to Pages.
          </p>
        </div>
        <a class="btn btn-primary" href={`${base}docs/introduction/`}>Read the manual</a>
      </div>
    </section>

    <section id="install" class="wrap-wide home-section home-section--last">
      <div class="home-section-head">
        <h2 class="home-section-title">Install</h2>
        <p class="home-section-sub">
          Binary via Cargo. The crate lives at the repository root; this site under <code>docs/</code> is excluded from <code>cargo package</code>.
        </p>
      </div>
      <div class="home-install-grid">
        <div class="home-install-card">
          <h3 class="home-install-h">crates.io</h3>
          <pre><code>cargo install g
g --version</code></pre>
          <p class="home-install-note">Adjust the crate name if yours differs on crates.io.</p>
        </div>
        <div class="home-install-card">
          <h3 class="home-install-h">From source</h3>
          <pre><code>git clone https://github.com/YOUR_ORG/vcli.git
cd vcli
cargo install --path .</code></pre>
          <p class="home-install-note">Keep <code>~/.cargo/bin</code> on your <code>PATH</code>.</p>
        </div>
      </div>
      <p class="home-token-hint">
        For <code>g stack pr</code>, set <code>GITHUB_TOKEN</code> or <code>[github].token</code> in <code>~/.config/g/config.toml</code>.
      </p>
    </section>
  </main>

  <footer class="doc-footer">
    <div class="wrap-wide doc-footer-inner">
      <span>MIT · g · Astro + React</span>
      <a href={github} rel="noopener noreferrer">Source</a>
    </div>
  </footer>

  <style>
    .home-main {
      flex: 1;
    }

    .home-hero {
      padding: 3rem 0 2.5rem;
    }

    .home-hero-grid {
      display: grid;
      grid-template-columns: 1fr minmax(0, 1fr);
      gap: 2.75rem;
      align-items: start;
    }

    @media (max-width: 980px) {
      .home-hero-grid {
        grid-template-columns: 1fr;
      }
    }

    .home-hero-eyebrow {
      margin-bottom: 1rem;
    }

    .home-hero-title {
      margin: 0 0 1rem;
      font-size: clamp(2.35rem, 5vw, 3.4rem);
      line-height: 1.05;
      letter-spacing: -0.045em;
      font-weight: 800;
    }

    .home-hero-grad {
      display: inline-block;
      background: linear-gradient(115deg, #00f5ff, #c084fc, #fb7185, #a3e635);
      background-size: 200% auto;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .home-hero-lede {
      margin: 0 0 1.5rem;
      font-size: 1.12rem;
      color: #a4a8b8;
      max-width: 36rem;
      line-height: 1.65;
    }

    .home-hero-strong {
      color: var(--text);
    }

    .home-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin-bottom: 1.35rem;
    }

    .home-hero-bullets {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
      font-size: 0.82rem;
      color: var(--muted);
    }

    .home-hero-bullets li {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .home-hero-bullets li::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      box-shadow: 0 0 10px rgba(0, 245, 255, 0.5);
    }

    .home-hero-panel {
      padding: 1.15rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--bg-card);
      backdrop-filter: blur(14px);
      box-shadow: var(--shadow), var(--shadow-glow);
    }

    .home-section {
      padding: 2.5rem 0;
    }

    .home-section--last {
      padding-bottom: 4rem;
    }

    .home-section-head {
      margin-bottom: 1.5rem;
      max-width: 40rem;
    }

    .home-section-title {
      margin: 0 0 0.4rem;
      font-size: 1.65rem;
      letter-spacing: -0.03em;
      font-weight: 700;
    }

    .home-section-sub {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.55;
    }

    .home-section-sub a {
      font-weight: 600;
    }

    .home-plays {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    @media (max-width: 1024px) {
      .home-plays {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .home-plays {
        grid-template-columns: 1fr;
      }
    }

    .home-play-card {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.55rem;
      padding: 1.15rem 1.2rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: linear-gradient(160deg, rgba(16, 18, 32, 0.9), rgba(8, 9, 16, 0.92));
      text-decoration: none !important;
      transition:
        transform 0.16s ease,
        border-color 0.16s ease,
        box-shadow 0.16s ease;
      min-height: 100%;
    }

    .home-play-card:hover {
      transform: translateY(-3px);
      border-color: rgba(192, 132, 252, 0.4);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
    }

    .home-play-title {
      font-weight: 700;
      font-size: 1.02rem;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .home-play-desc {
      font-size: 0.86rem;
      line-height: 1.5;
      color: #9aa0b4;
      flex: 1;
    }

    .home-play-cta {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--accent);
      margin-top: 0.25rem;
    }

    .home-cap-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    @media (max-width: 720px) {
      .home-cap-grid {
        grid-template-columns: 1fr;
      }
    }

    .home-cap {
      padding: 1.35rem 1.4rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: rgba(12, 14, 24, 0.55);
      backdrop-filter: blur(12px);
    }

    .home-cap-title {
      margin: 0 0 0.5rem;
      font-size: 1.08rem;
      color: #fff;
      letter-spacing: -0.02em;
    }

    .home-cap-body {
      margin: 0 0 0.85rem;
      font-size: 0.92rem;
      color: #a7abbd;
      line-height: 1.55;
    }

    .home-cap-cmd {
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .home-cap-cmd code {
      font-size: 0.72rem;
    }

    .home-band {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      align-items: center;
      justify-content: space-between;
      padding: 1.85rem 2rem;
      border-radius: var(--radius);
      border: 1px solid rgba(0, 245, 255, 0.2);
      background: linear-gradient(
        125deg,
        rgba(0, 245, 255, 0.1),
        rgba(192, 132, 252, 0.09),
        rgba(251, 113, 133, 0.06)
      );
      box-shadow: var(--shadow-glow);
    }

    .home-band-title {
      margin: 0 0 0.35rem;
      font-size: 1.35rem;
      letter-spacing: -0.03em;
    }

    .home-band-text {
      margin: 0;
      color: #aeb2c4;
      max-width: 46ch;
      line-height: 1.55;
    }

    .home-install-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    @media (max-width: 720px) {
      .home-install-grid {
        grid-template-columns: 1fr;
      }
    }

    .home-install-card {
      padding: 1.35rem 1.4rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--bg-card);
      backdrop-filter: blur(12px);
    }

    .home-install-h {
      margin: 0 0 0.65rem;
      font-size: 1rem;
    }

    .home-install-note {
      margin: 0.75rem 0 0;
      font-size: 0.82rem;
      color: var(--muted);
    }

    .home-token-hint {
      margin: 1.35rem 0 0;
      font-size: 0.9rem;
      color: var(--muted);
    }
  </style>
</Layout>
